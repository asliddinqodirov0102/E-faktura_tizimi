# ============================================================
# .env.example — Muhit o'zgaruvchilari namunasi
# Bu faylni nusxalab, ".env" nomi bilan saqlang
# va haqiqiy qiymatlarni kiriting.
# ============================================================

# --- Ilova sozlamalari ---
APP_NAME="Elektron Hisob-Faktura Tizimi"
APP_VERSION="1.0.0"
DEBUG=False

# --- PostgreSQL ma'lumotlar bazasi ---
# Lokal ishlab chiqish uchun:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/efaktura_db
#
# Render.com PostgreSQL uchun (Render dashboard'dan oling):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Xavfsizlik ---
# SECRET_KEY ni terminalda generatsiya qiling:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Birinchi Admin (ilk ishga tushirishda avtomatik yaratiladi) ---
# Ilova birinchi marta ishga tushganda, bazada admin yo'q bo'lsa,
# ushbu ma'lumotlar bilan admin avtomatik yaratiladi.
# Keyin parolni /api/v1/auth/register orqali o'zgartiring!
FIRST_ADMIN_LOGIN=admin
FIRST_ADMIN_PASSWORD=Admin@12345
FIRST_ADMIN_NAME=Bosh Administrator

# --- CORS sozlamalari ---
# Frontend URL manzillarini vergul bilan ajrating
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Server sozlamalari (Render.com uchun) ---
PORT=8000
